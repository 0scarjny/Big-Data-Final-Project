# Copy this file to .streamlit/secrets.toml and fill in the values for local
# development or Streamlit Community Cloud. On Google Cloud Run, leave
# `gcp_service_account` absent — Application Default Credentials are picked up
# automatically from the attached service account.

# --- Authentication (login gate) ---------------------------------------------
# The dashboard requires login by default. To disable for local dev, set
# `enabled = false`. Generate a long random cookie_key with e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
[auth]
enabled            = true
cookie_name        = "weather_dashboard_auth"
cookie_key         = ""        # REQUIRED: a long random string
cookie_expiry_days = 1
auto_hash          = true      # set to false once you replace plaintext
                               # passwords with bcrypt hashes generated by
                               # `python hash_password.py`

# One subsection per user. `password` may be plaintext (when auto_hash = true)
# or a bcrypt hash (when auto_hash = false). Roles and email/first/last names
# are optional but appear in the welcome message.
[auth.credentials.usernames.admin]
email      = "admin@example.com"
first_name = "Admin"
last_name  = "User"
password   = "change-me"       # plaintext OR pre-hashed (see hash_password.py)
roles      = ["admin"]

# --- Application configuration ------------------------------------------------
[app]
gcp_project_id      = "data-buckets-489022"
bq_dataset          = "weather_records"
bq_table            = "weather-data"
flask_base_url      = "https://flask-app-868833155300.europe-west6.run.app"
flask_shared_secret = ""                       # PASSWORD_HASH from Flask/src/clients.py
default_location    = "Lausanne"
refresh_interval_s  = 60

# --- Service-account JSON for local / Streamlit Cloud only --------------------
# Paste the full service-account key here. Remove this whole section when
# deploying to Cloud Run with an attached service account.
[gcp_service_account]
type                        = "service_account"
project_id                  = ""
private_key_id              = ""
private_key                 = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email                = ""
client_id                   = ""
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = ""
universe_domain             = "googleapis.com"
